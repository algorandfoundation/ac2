{
  "name": "@algorandfoundation/ac2-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the AC2 (Agentic Communication and Control) protocol.",
  "keywords": [
    "ac2",
    "algorand",
    "didcomm",
    "webrtc",
    "agent",
    "wallet",
    "signing"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/algorandfoundation/ac2/tree/main/packages/ac2-sdk#readme",
  "bugs": {
    "url": "https://github.com/algorandfoundation/ac2/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algorandfoundation/ac2.git",
    "directory": "packages/ac2-sdk"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "default": "./dist/protocol/index.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "default": "./dist/transport/index.js"
    },
    "./signaling": {
      "types": "./dist/signaling/index.d.ts",
      "default": "./dist/signaling/index.js"
    }
  },
  "scripts": {
    "prepare": "tsc -p tsconfig.build.json",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run --globals",
    "test:watch": "vitest --globals",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "release": "package-releaser"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@algorandfoundation/package-releaser": "workspace:*",
    "@types/node": "catalog:",
    "typedoc": "^0.28.19",
    "typescript": "catalog:",
    "vitest": "^3.2.0"
  }
}
